{
  "mcpServers": {
    "amap-geo-assistant": {
      "command": "npx",
      "args": [
        "-y",
        "api2mcp",
        "--url",
        "https://raw.giteeusercontent.com/shenjingnan/api2mcp/raw/main/examples/amap-geo-assistant/openapi.yaml",
        "--base-url",
        "https://restapi.amap.com"
      ],
      "env": {
        "API_FIXED_PARAMS": "key=YOUR_AMAP_KEY"
      }
    }
  }
}
