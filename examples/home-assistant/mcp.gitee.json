{
  "mcpServers": {
    "home-assistant": {
      "command": "npx",
      "args": [
        "-y",
        "api2mcp",
        "--url",
        "https://raw.giteeusercontent.com/shenjingnan/api2mcp/raw/main/examples/home-assistant/openapi.yaml",
        "--base-url",
        "http://localhost:8123"
      ],
      "env": {
        "API_HEADERS": "Authorization=Bearer YOUR_HA_TOKEN"
      }
    }
  }
}
