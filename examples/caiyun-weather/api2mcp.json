{
  "mcpServers": {
    "caiyun-weather": {
      "command": "node",
      "args": [
        "api2mcp",
        "--url",
        "https://raw.githubusercontent.com/shenjingnan/api2mcp/refs/heads/main/examples/caiyun-weather/openapi.yaml",
        "--base-url",
        "https://api.caiyunapp.com"
      ],
      "env": {
        "appKey": "YOUR_APP_KEY"
      }
    }
  }
}
