{
  "openapi": "3.0.0",
  "info": {
    "title": "Security Test API",
    "version": "1.0.0"
  },
  "security": [
    { "bearerAuth": [] }
  ],
  "paths": {
    "/secure": {
      "get": {
        "operationId": "getSecure",
        "summary": "Get secure data",
        "security": [
          { "apiKeyAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "post": {
        "operationId": "postSecure",
        "summary": "Post secure data",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/public": {
      "get": {
        "operationId": "getPublic",
        "summary": "Get public data",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      },
      "queryApiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        },
        "required": ["id", "name"]
      }
    }
  }
}
