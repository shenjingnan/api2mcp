{
  "openapi": "3.0.0",
  "info": {
    "title": "X-Fixed Test API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/data": {
      "get": {
        "summary": "Get data",
        "operationId": "getData",
        "parameters": [
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "x-fixed": true,
            "description": "API key auto-injected via x-fixed",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/{projectId}/items": {
      "get": {
        "summary": "Get items",
        "operationId": "getItems",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "x-fixed": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  }
}
