{
  "name": "api2mcp",
  "version": "0.6.0",
  "description": "将 OpenAPI/Swagger 规范一键转换为 MCP 工具，让 AI 助手无缝调用您的 API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "api2mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "spellcheck": "cspell lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "release-it",
    "release:beta": "release-it --preRelease=beta --ci",
    "release:patch": "release-it patch --ci",
    "release:minor": "release-it minor --ci",
    "release:major": "release-it major --ci",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "openapi",
    "swagger",
    "api",
    "model-context-protocol"
  ],
  "author": "shenjingnan <sjn.code@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shenjingnan/api2mcp.git"
  },
  "bugs": {
    "url": "https://github.com/shenjingnan/api2mcp/issues"
  },
  "homepage": "https://github.com/shenjingnan/api2mcp#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.1",
    "cspell": "^9.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "openapi-types": "^12.1.3",
    "release-it": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.1"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
